# .env.example.comol
# Скопируйте в .env.comol и заполните реальными лицензионными ключами:
#   cp .env.example.comol .env.comol
#
# Запуск:
#   docker compose -f docker-compose.comol.yml --env-file .env.comol up -d

# === Лицензионные ключи (обязательно) ===
LICENSE_KEY_HELP=your-help-license-key-here
LICENSE_KEY_TEMPLATES=your-templates-license-key-here
LICENSE_KEY_SYNTAX=your-syntax-license-key-here
LICENSE_KEY_SSL=your-ssl-license-key-here

# === Версия БСП для SSL-сервера ===
SSL_VERSION=3.1.11

# === Порты (по умолчанию не конфликтуют с основным docker-compose.yml) ===
# COMOL_HELP_PORT=8003
# COMOL_TEMPLATES_PORT=8004
# COMOL_SYNTAX_PORT=8002
# COMOL_SSL_PORT=8008

# === Общие настройки ===
# COMOL_USESSE=false          # true для Legacy-клиентов (SSE-транспорт)

# === Настройки кэширования (per-service) ===
# COMOL_HELP_RESET_CACHE=false
# COMOL_HELP_RESET_DATABASE=false
# COMOL_TEMPLATES_RESET_CACHE=false
# COMOL_TEMPLATES_RESET_DATABASE=false
# COMOL_SSL_RESET_CACHE=false
# COMOL_SSL_RESET_DATABASE=false

# === Путь к бинарникам платформы 1С (для 1c-help-mcp, macOS) ===
# ONEC_BIN_PATH=/opt/1cv8/current/bin
